# ─────────────────────────────────────────────
# ARGUS — Environment Configuration
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Web UI port (local only, binds to 127.0.0.1)
PORT=4000

# Web UI password — leave blank to disable auth (not recommended on VPS)
WEB_PASSWORD=

# ── Telegram ──────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal chat ID (send /start to @userinfobot)
TELEGRAM_CHAT_ID=

# ── Solana RPC ────────────────────────────────
# Helius free tier: https://helius.dev
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
HELIUS_API_KEY=

# ── Data Sources ──────────────────────────────
# Birdeye API (Phase 1 — OHLCV). Free tier available.
# Until then, DexScreener is used as fallback (no key needed)
BIRDEYE_API_KEY=

# ── Wallet Observer (Phase 3) ─────────────────
# Your Solana wallet PUBLIC ADDRESS only — no private key here
WATCH_WALLET=

# ── Risk Limits ───────────────────────────────
RISK_MAX_POSITIONS=5
RISK_MAX_DAILY_LOSS=50

# ── Debug ─────────────────────────────────────
DB_VERBOSE=0
